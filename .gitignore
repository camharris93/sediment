# Warehouse — regenerated by `make up`, never committed.
*.duckdb
*.duckdb.wal

# Generated artifacts
profile.json
.cache/

# ── AnAge is the ONLY dataset that ships ────────────────────────────────────
# This repo is AnAge-only by design. Every OTHER dataset you onboard locally —
# its config, data, generated models — stays on your machine and is never
# committed. (To share a different dataset, that's a separate repo.)
datasets/*
!datasets/anage
# Within AnAge: keep config + source data (so the worked example runs offline),
# drop derived/generated artifacts and the re-downloadable zip.
datasets/anage/profile.json
datasets/anage/data/*.zip
datasets/*/scaffold/

# Only AnAge's dbt models are tracked; any other dataset's models (named
# <dataset>__*) stay local, matching the dataset-isolation above.
dbt_project/models/staging/*__*
dbt_project/models/marts/*__*
!dbt_project/models/staging/anage__*
!dbt_project/models/marts/anage__*

# dbt
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
.user.yml

# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# Packaging / build & tooling caches
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/

# Secrets — AI layers read the key from here if env var is unset.
anthropic.txt

# OS
.DS_Store
Thumbs.db
