# Warehouse — regenerated by `make up`, never committed.
*.duckdb
*.duckdb.wal

# Generated artifacts
profile.json
datasets/*/profile.json
.cache/

# ── Ship the recipe, not the data ──────────────────────────────────────────
# Raw dataset files stay LOCAL: a push carries the pipeline (config.yml, the dbt
# staging/mart models, _sources.yml, tests) but NOT the bytes. A teammate clones,
# drops their own file into datasets/<name>/data/, and runs `up`.
datasets/*/data/*
# Exception: the AnAge reference data ships so the worked example runs offline
# (it also re-downloads from its URL, so this is belt-and-suspenders)...
!datasets/anage/data/*
# ...but never the re-downloadable zip.
datasets/anage/data/*.zip

# dbt
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
.user.yml

# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# Secrets — AI layers read the key from here if env var is unset.
anthropic.txt

# OS
.DS_Store
Thumbs.db
